{
    "name": "بن عبود للصرافة",
    "short_name": "بن عبود",
    "description": "Web app to manage client transactions, exchanges, deposits, and debts.",
    "start_url": "/index.php",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#0066cc",
    "orientation": "landscape-primary",
    "scope": "/",
    "lang": "ar",
    "dir": "rtl",
    "icons": [
        {
            "src": "images/icons/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "images/icons/icon-maskable-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        },
        {
            "src": "images/icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "images/icons/icon-maskable-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "screenshots": [
        {
            "src": "images/screenshots/desktop-screenshot.png",
            "sizes": "1920x1080",
            "type": "image/png",
            "form_factor": "wide",
            "label": "Exchanges on Desktop"
        },
        {
            "src": "images/screenshots/mobile-screenshot.jpg",
            "sizes": "572x1280",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "Exchanges on Mobile"
        }
    ],
    "launch_handler": {
        "client_mode": "focus-existing"
    },
    "display_override": [
        "standalone",
        "window-controls-overlay"
    ]
}

